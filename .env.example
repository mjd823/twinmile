# Obtain a connection string for your database from the Clusters tab on the MongoDB Atlas Dashboard.
# The connection string has the format `mongodb+srv://myDatabaseUser:D1fficultP%40ssw0rd@cluster0.example.mongodb.net/?retryWrites=true&w=majority`
MONGODB_URI=your-string-here

# Groq AI Agent Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Resend (email notifications for new leads)
# Sign up at https://resend.com, get your API key from the dashboard.
# Before domain verification, emails send from onboarding@resend.dev.
# After verifying contact.twinmile.com, set RESEND_FROM_EMAIL to e.g. alerts@contact.twinmile.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_NOTIFY_TO=admin@twinmile.com

# Cron route protection (/api/cron/*)
# Required — the cron routes return 500 if unset. Generate with: openssl rand -hex 32
# Vercel automatically sends "Authorization: Bearer <CRON_SECRET>" on cron invocations
# when this env var is set on the project; manual calls may instead send an
# "x-cron-secret: <CRON_SECRET>" header.
CRON_SECRET=

# FMCSA prospecting (/api/cron/prospecting) — all optional.
# Comma-separated target states, max prospects saved per run, and an optional
# Socrata app token (data.transportation.gov) for higher rate limits.
FMCSA_TARGET_STATES=TX,LA,CA,GA,TN
FMCSA_MAX_RESULTS=30
SOCRATA_APP_TOKEN=

# Outreach email safety gate for /api/cron/process-outreach.
# The route runs in DRY-RUN mode (reports what would send, sends nothing,
# claims nothing) unless this is set to exactly "live".
OUTREACH_AUTOMATION=
